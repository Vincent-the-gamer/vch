{
  "name": "vch",
  "version": "0.1.0",
  "type": "module",
  "description": "Quickly check versions of your toolchains.",
  "author": "Vincent-the-gamer",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist",
    "*.d.ts"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "bin": {
    "vch": "bin/vch.js"
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.mts"
      ]
    }
  },
  "scripts": {
    "tsx": "tsx",
    "build": "tsdown",
    "test": "vitest",
    "dep": "taze major -I"
  },
  "license": "MIT",
  "homepage": "https://github.com/Vincent-the-gamer/vch#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vincent-the-gamer/vch.git"
  },
  "bugs": {
    "url": "https://github.com/Vincent-the-gamer/vch/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.com",
    "access": "public"
  },
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^25.5.0",
    "taze": "^19.10.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "cac": "^7.0.0",
    "cheerio": "^1.2.0",
    "consola": "^3.4.2",
    "restore-cursor": "^5.1.0"
  }
}
